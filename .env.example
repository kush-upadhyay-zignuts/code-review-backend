# Server
BACKEND_PORT=3001
NODE_ENV=development
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URL=mongodb://localhost:27017/code_review

# Redis (optional — uses in-memory cache if not set)
REDIS_URL=

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d


# Open ai API / LLM
# AI_API_KEY=your_openai_api_key_here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI / LLM (OpenRouter — OpenAI-compatible API)
AI_API_KEY=your_openrouter_api_key_here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-oss-20b:free
AI_MAX_OUTPUT_TOKENS=16384
AI_VALIDATOR_ENABLED=false
AI_MIN_CONFIDENCE=80

# Optional OpenRouter attribution headers
AI_APP_URL=http://localhost:3000
AI_APP_NAME=CodeReview AI

# Rate limiting & token budget
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
MONTHLY_TOKEN_BUDGET=100000

# Email (forgot password) — SMTP is the default
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Optional: HTTPS API fallback (only used when BOTH vars below are set)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=CodeReview AI <noreply@yourdomain.com>

# Must match your deployed frontend URL (reset links in emails)
FRONTEND_URL=http://localhost:3000
