# Server
BACKEND_PORT=3001
NODE_ENV=development
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URL=mongodb://localhost:27017/code_review

# Redis (optional — uses in-memory cache if not set)
REDIS_URL=

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# AI / LLM
AI_API_KEY=your_openai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_OUTPUT_TOKENS=4096
AI_VALIDATOR_ENABLED=true
AI_MIN_CONFIDENCE=80

# Rate limiting & token budget
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
MONTHLY_TOKEN_BUDGET=100000

# Email (forgot password)
# Local: Gmail SMTP works (use an App Password, not your account password)
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=

# Dev/prod on Render free tier: SMTP ports 587/465 are BLOCKED — use Resend instead (HTTPS)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=CodeReview AI <onboarding@resend.dev>

# Must match your deployed frontend URL (reset links in emails)
FRONTEND_URL=http://localhost:3000
